  "issues": [
    {
      "id": 1,
      "title": "N+1 Problem: refreshAllPrices Loop Update",
      "severity": "CRITICAL",
      "category": "database",
      "location": "src/modules/investment/services/investment.service.ts:300-350",
      "methods_affected": [
        "refreshAllPrices()",
        "refreshPrices(user)"
      ],
      "description": "Loop executando update individual para cada investment. Com 500 investments = 501 queries.",
      "current_pattern": "for (const inv of investments) { await knex('investments').where({id}).update(...) }",
      "impact": {
        "queries_before": 501,
        "queries_after": 2,
        "time_before_ms": 5000,
        "time_after_ms": 800,
        "improvement_percent": 99.6
      },
      "frequency": "Every 15 minutes (96x per day)",
      "fix_approach": "Batch update com CASE/WHEN ou VALUES clause",
      "implementation_hours": 4,
      "priority": 1,
      "code_snippet": {
        "before": "for (const investment of investments) { await this.knex('investments').where({id}).update(...) }",
        "after": "await this.knex.raw('UPDATE investments SET current_price = CASE id WHEN ? THEN ? ... END WHERE id IN (...)')"
      }
    },
    {
      "id": 2,
      "title": "Missing Cache on External API (BRAPI)",
      "severity": "CRITICAL",
      "category": "caching",
      "location": "src/modules/investment/services/investment.service.ts:100-130",
      "methods_affected": [
        "fetchCurrentPrices()",
        "refreshAllPrices()",
        "refreshPrices()"
      ],
      "description": "API external calls sem cache. BRAPI com rate limit de 500 requests/dia.",
      "current_pattern": "await fetch(url) without caching",
      "impact": {
        "requests_before_per_day": 336,
        "requests_after_per_day": 96,
        "requests_saved": 240,
        "improvement_percent": 71.4,
        "cache_ttl_seconds": 300
      },
      "frequency": "Every 15 minutes (96x per day)",
      "fix_approach": "CacheService com Redis e TTL de 5 minutos",
      "implementation_hours": 2,
      "priority": 2,
      "code_snippet": {
        "before": "const stockData = await this.fetchJson(url)",
        "after": "const stockData = await this.cacheService.getOrSet(key, () => this.fetchJson(url), 300)"
      }
    },
    {
