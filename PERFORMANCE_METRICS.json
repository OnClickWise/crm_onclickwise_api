      "priority": 3
    },
    {
      "id": 4,
      "title": "SELECT Wildcard (*) Fetching Unused Columns",
      "severity": "MEDIUM",
      "category": "database",
      "location": "src/modules/investment/services/investment.service.ts:178, 197, 217",
      "methods_affected": [
        "listInvestments()",
        "getInvestmentById()",
        "updateInvestment()"
      ],
      "description": "Selecionando inv.* e p.* traz todas as 15 colunas quando listagem precisa apenas de 11.",
      "tables_affected": ["investments", "portfolios", "contributions"],
      "current_pattern": ".select('inv.*', 'p.name as portfolio_name')",
      "impact": {
        "unnecessary_columns_percent": 27,
        "network_transfer_reduction_percent": 25,
        "query_size_reduction_percent": 30
      },
      "implementation_hours": 2,
      "priority": 4,
      "code_snippet": {
        "before": ".select('inv.*', 'p.name as portfolio_name')",
        "after": ".select('inv.id', 'inv.asset_name', 'inv.quantity', 'inv.current_price', ..., 'p.name as portfolio_name')"
      }
    },
    {
      "id": 5,
      "title": "Subquery Agregação Sem Cache",
      "severity": "MEDIUM",
      "category": "caching",
      "location": "src/modules/portfolio/services/portfolio.service.ts:45-75",
      "methods_affected": [
        "listPortfolios()",
        "getPortfolioById()"
      ],
      "description": "Subquery de investimentos agregados executa toda vez. Cálculos pesados sem cache.",
      "current_pattern": "LEFT JOIN (SELECT SUM(...) GROUP BY portfolio_id)",
      "impact": {
        "queries_saved_per_request": 1,
        "time_reduction_ms": 250,
        "cache_hit_potential_percent": 80
      },
      "cache_ttl_seconds": 300,
      "implementation_hours": 3,
      "priority": 5,
      "code_snippet": {
        "before": "let query = knex(...).leftJoin(investmentsSumSubquery, ...)",
        "after": "let query = await this.cacheService.getOrSet(`portfolio:${id}`, () => knex(...), 300)"
      }
    },
